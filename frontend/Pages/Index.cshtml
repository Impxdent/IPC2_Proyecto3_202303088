@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="container py-4">
    <div class="row align-items-center mb-5">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold text-dark">Bienvenido al Sistema Financiero</h1>
            <p class="lead text-muted">Gestión integral de cobros, pagos y estados de cuenta con procesamiento incremental.</p>
        </div>
    </div>

    <h3 class="mb-4">¿Cómo funciona el sistema?</h3>
    
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <div class="text-primary fs-1 mb-3"><i class="bi bi-1-circle-fill"></i></div>
                    <h5 class="card-title fw-bold">Configuración Inicial</h5>
                    <p class="card-text text-muted">Suba el archivo <code>config.xml</code> para registrar Clientes y Bancos autorizados. El sistema detecta nuevos registros o actualiza los existentes.</p>
                    <a asp-page="/CargarConfig" class="btn btn-outline-primary btn-sm">Ir a Configurar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <div class="text-success fs-1 mb-3"><i class="bi bi-2-circle-fill"></i></div>
                    <h5 class="card-title fw-bold">Carga de Movimientos</h5>
                    <p class="card-text text-muted">Cargue el archivo <code>transac.xml</code>. El sistema procesará facturas y aplicará pagos automáticamente bajo la lógica <strong>FIFO</strong> (Primero en entrar, primero en salir).</p>
                    <a asp-page="/CargarTransac" class="btn btn-outline-success btn-sm">Subir Transacciones</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <div class="text-warning fs-1 mb-3"><i class="bi bi-3-circle-fill"></i></div>
                    <h5 class="card-title fw-bold">Consultas y Reportes</h5>
                    <p class="card-text text-muted">Consulte el estado de cuenta por NIT para ver el historial de cargos, abonos y el saldo actual (incluyendo saldos a favor).</p>
                    <a asp-page="/Consultas/EstadoCuenta" class="btn btn-outline-warning btn-sm text-dark">Ver Estados</a>
                </div>
            </div>
        </div>
    </div>

</div>

