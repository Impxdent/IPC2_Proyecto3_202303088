@page
@model CargarTransacModel
@{
    ViewData["Title"] = "Cargar Transacciones";
}

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Cargar Facturas y Pagos</h3>
        </div>
        <div class="card-body">
            <p>Seleccione el archivo <strong>transac.xml</strong> para ver movimientos</p>
            
            <form method="post" enctype="multipart/form-data">
                <div class="input-group mb-3">
                    <input type="file" class="form-control" name="archivoXml" accept=".xml" required>
                    <button class="btn btn-primary" type="submit">Procesar</button>
                </div>
            </form>

            @if (Model.Mensaje != null)
            {
                <div class="alert @(Model.Error ? "alert-danger" : "alert-success")">
                    @Model.Mensaje
                </div>
            }
        </div>
    </div>
</div>