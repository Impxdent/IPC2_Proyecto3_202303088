<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - Sistema Financiero</title>
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <style>
            :root {
                --primary-color: #0d47a1;
                --secondary-color: #f8f9fa;
            }
            body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
            .navbar-custom { background-color: var(--primary-color); padding: 0.8rem; }
            .navbar-brand { font-weight: bold; letter-spacing: 1px; }
            .nav-link { color: rgba(255,255,255,0.8) !important; transition: 0.3s; margin: 0 5px; }
            .nav-link:hover { color: white !important; background: rgba(255,255,255,0.1); border-radius: 8px; }
            footer { background: white; padding: 20px 0; margin-top: 50px; }
        </style>
    </head>
    <body>
        <header>
            <nav class="navbar navbar-expand-lg navbar-dark navbar-custom mb-4 shadow-sm">
                <div class="container">
                    <a class="navbar-brand" asp-page="/Index">ITSGA</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Index"><i class="bi bi-house-door me-1"></i> Inicio</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/CargarConfig"><i class="bi bi-gear me-1"></i> Configuración</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/CargarTransac"><i class="bi bi-arrow-left-right me-1"></i> Transacciones</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Consultas/EstadoCuenta"><i class="bi bi-file-earmark-text me-1"></i> Estado de Cuenta</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Consultas/Ingresos">Consultar Ingresos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Ayuda"><i class="bi bi-question-circle me-1"></i> Ayuda</a>
                            </li>
                            <li class="nav-item ms-lg-3">
                                <button type="button" class="btn btn-outline-danger" onclick="limpiarTodoElSistema()">Limpiar Datos</button>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="container">
            <main role="main" class="pb-5">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top text-center">
            <div class="container">
                <p class="mb-0">&copy; 2026 - Eldan André Escobar Asturias - Derechos de autor</p>
            </div>
        </footer>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>

        <script>
            async function limpiarTodoElSistema() {
                if (!confirm("¿Estás seguro de que deseas eliminar todos los datos del sistema?")) return;

                try {
                    const response = await fetch('http://localhost:5142/limpiarDatos', {
                        method: 'POST'
                    });

                    const data = await response.json();

                    if (response.ok) {
                        alert(data.mensaje);
                        window.location.href = '/Index'; 
                    } else {
                        alert("Error al limpiar: " + (data.mensaje || "Error desconocido"));
                    }
                } catch (error) {
                    console.error("Error:", error);
                    alert("No se pudo conectar con el servidor backend en el puerto 5142.");
                }
            }
        </script>

        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>