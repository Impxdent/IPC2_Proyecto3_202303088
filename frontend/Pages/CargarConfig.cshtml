@page
@model CargarConfigModel
@{
    ViewData["Title"] = "Cargar Configuración";
}

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Cargar configuración</h3>
        </div>
        <div class="card-body">
            <p>Seleccione el archivo <strong>config.xml</strong> para ver configuración</p>
            <form method="post" enctype="multipart/form-data">
                <div class="input-group mb-3">
                    <input class="form-control" type="file" name="archivoXml" accept=".xml" required>
                    <button type="submit" class="btn btn-primary">Procesar</button>
                </div>
            </form>
            
            @if (!string.IsNullOrEmpty(Model.Mensaje)) {
                <div class="alert mt-3 @(Model.Error ? "alert-danger" : "alert-success")">
                    @Model.Mensaje
                </div>
            }
        </div>
    </div>
</div>

    @if (Model.MostrarTabla)
    {
        <div id="resultadoTabla" class="mt-4">
            <table class="table table-bordered text-center shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th></th>
                        <th>Creados</th>
                        <th>Actualizados</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-bold">Clientes</td>
                        <td>@Model.ClientesC</td>
                        <td>@Model.ClientesA</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Bancos</td>
                        <td>@Model.BancosC</td>
                        <td>@Model.BancosA</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }