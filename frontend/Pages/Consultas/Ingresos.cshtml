@page
<div class="container no-print">
    <h2 class="mb-4">Consultar Ingresos por Banco</h2>
    
    <div class="row g-3 align-items-end mb-5 bg-white p-3 rounded shadow-sm">
        <div class="col-md-3">
            <label>Mes</label>
            <select id="mes" class="form-select">
                <option value="1">Enero</option>
                <option value="2">Febrero</option>
                <option value="3">Marzo</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>Año</label>
            <input type="number" id="anio" class="form-control" value="2024">
        </div>
        <div class="col-md-3">
            <button onclick="cargarGrafica()" class="btn btn-primary w-100">Procesar</button>
        </div>
        <div class="col-md-3">
            <button onclick="window.print()" class="btn btn-danger w-100">Guardar como PDF</button>
        </div>
    </div>
</div>

<div id="contenedorGrafica" class="bg-white p-5 rounded shadow">
    </div>

<style>
    @@media print {
        .no-print { display: none !important; }
        body { background: white; }
    }
</style>