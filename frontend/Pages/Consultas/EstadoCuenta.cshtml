@page "{nit?}"
@model frontend.Pages.Consultas.EstadoCuentaModel
@{
    ViewData["Title"] = "Estado de Cuenta";
}

<div class="container mt-4">
    <h2>Consulta de Estado de Cuenta</h2>
    
    <form method="get" class="row g-3 mb-4">
        <div class="col-auto">
            <input type="text" name="nit" class="form-control" placeholder="Ingrese NIT (opcional)">
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Consultar</button>
        </div>
    </form>

    @foreach (var item in Model.Resultados)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-light">
                <strong>Cliente:</strong> @item.Nit - @item.NombreCliente <br />
                <strong>Saldo actual:</strong> Q. @item.SaldoActual.ToString("N2")
            </div>
            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Descripción</th>
                            <th>Monto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trans in item.Historial)
                        {
                            <tr>
                                <td>@trans.Fecha</td>
                                <td><span class="badge @(trans.Tipo == "Cargo" ? "bg-danger" : "bg-success")">@trans.Tipo</span></td>
                                <td>@trans.Descripcion</td>
                                <td>Q. @trans.Monto.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>